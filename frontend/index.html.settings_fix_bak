        async uploadEmlFile() {
          if (!this.emlAnalysisFile) {
            this.showToast('warning', 'File Required', 'Please select a .eml file to analyze');
            return;
          }

          const filename = this.emlAnalysisFile.name || '';
          if (!filename.toLowerCase().endsWith('.eml')) {
            this.emlAnalysisError = 'Only .eml files are allowed.';
            return;
          }

          if (this.emlAnalysisFile.size > 500 * 1024) {
            this.emlAnalysisError = 'File too large. Max size is 500KB.';
            return;
          }

          this.emlAnalysisLoading = true;
          this.emlAnalysisError = null;

          try {
            const formData = new FormData();
            formData.append('file', this.emlAnalysisFile);

            const response = await fetch(`${this.API_BASE}/api/deliverability-analysis/upload-eml`, {
              method: 'POST',
              body: formData
            });

            if (!response.ok) {
              const errorText = await response.text();
              throw new Error(errorText || 'Failed to analyze .eml file');
            }

            const result = await response.json();
            this.emlAnalysisReport = result.report || null;
            this.showToast('success', 'Analysis Complete', 'Deliverability report generated');
          } catch (error) {
            console.error('EML analysis error:', error);
            this.emlAnalysisError = error.message || 'Failed to analyze .eml file.';
            this.showToast('error', 'Analysis Failed', this.emlAnalysisError);
          } finally {
            this.emlAnalysisLoading = false;
          }
        },

        async exportEmlReportPdf() {
          if (!this.emlAnalysisReport || !this.emlAnalysisReport.email_id) {
            return;
          }

          try {
            const response = await fetch(`${this.API_BASE}/api/deliverability-analysis/report/${this.emlAnalysisReport.email_id}/pdf`);
            if (!response.ok) {
              throw new Error('Failed to export PDF');
            }

            const blob = await response.blob();
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `deliverability_analysis_${this.emlAnalysisReport.email_id}.pdf`;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
          } catch (error) {
            console.error('PDF export error:', error);
            this.showToast('error', 'Export Failed', error.message || 'Failed to export PDF');
          }
        },

