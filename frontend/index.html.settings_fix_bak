          const auth = report.authentication || {};
          const metrics = report.metrics || {};
          const issues = report.issues || [];

          const rows = [];

          const spfPass = (auth.spf || '').toLowerCase() === 'pass';
          const dkimPass = (auth.dkim || '').toLowerCase() === 'pass';
          const dmarcPass = (auth.dmarc || '').toLowerCase() === 'pass';
          rows.push({
            cat: 'Authentication',
            signal: `SPF ${auth.spf || 'unknown'}, DKIM ${auth.dkim || 'unknown'}, DMARC ${auth.dmarc || 'unknown'}`,
            score: (spfPass && dkimPass && dmarcPass) ? 'pos' : 'strongneg',
            label: (spfPass && dkimPass && dmarcPass) ? '👍 Positive' : '🚨 Strong Negative'
          });

          const hasListUnsub = !!metrics.list_unsubscribe_header;
          const hasBodyUnsub = !!metrics.has_unsubscribe;
          rows.push({
            cat: 'Compliance Signals',
            signal: `List-Unsubscribe: ${hasListUnsub ? 'present' : 'missing'}; Body unsubscribe: ${hasBodyUnsub ? 'present' : 'missing'}`,
            score: (hasListUnsub && hasBodyUnsub) ? 'pos' : 'strongneg',
            label: (hasListUnsub && hasBodyUnsub) ? '👍 Positive' : '🚨 Strong Negative'
          });

          const hiddenCount = metrics.hidden_char_count || 0;
          rows.push({
            cat: 'Content Integrity',
            signal: hiddenCount > 0 ? `Hidden characters detected (${hiddenCount})` : 'No hidden characters detected',
            score: hiddenCount > 0 ? 'strongneg' : 'pos',
            label: hiddenCount > 0 ? '🚨 Strong Negative' : '👍 Positive'
          });

          const spamHits = (metrics.spam_keyword_hits || []).length;
          rows.push({
            cat: 'Keyword Risk',
            signal: spamHits > 0 ? `Spam-like keywords detected (${spamHits})` : 'No spam keywords detected',
            score: spamHits > 0 ? 'medneg' : 'pos',
            label: spamHits > 0 ? '⚠️ Medium Negative' : '👍 Positive'
          });

          rows.push({
            cat: 'Content Balance',
            signal: metrics.image_text_ratio ? `Image/Text ratio ${metrics.image_text_ratio.toFixed(2)}` : 'Image/Text ratio unavailable',
            score: (metrics.image_text_ratio && metrics.image_text_ratio > 2.5) ? 'slightneg' : 'neutral',
            label: (metrics.image_text_ratio && metrics.image_text_ratio > 2.5) ? '⚠️ Slight Negative' : '⚠️ Neutral'
          });

          const redirectCount = (metrics.redirect_domains || []).length;
          rows.push({
            cat: 'Link Trust',
            signal: redirectCount ? `Tracking redirects detected (${redirectCount})` : 'No tracking redirects detected',
            score: redirectCount ? 'medneg' : 'pos',
            label: redirectCount ? '⚠️ Negative' : '👍 Positive'
          });
          rows.push({
            cat: 'Brand Consistency',
            signal: metrics.domain_alignment_issue ? 'From vs landing domains mismatch' : 'From vs landing domains aligned',
            score: metrics.domain_alignment_issue ? 'medneg' : 'pos',
            label: metrics.domain_alignment_issue ? '⚠️ Negative' : '👍 Positive'
          });
          const hasNonHttps = (metrics.non_https_links || []).length > 0;
          const hasBroken = (metrics.broken_links || []).length > 0;
          rows.push({
            cat: 'Link Hygiene',
            signal: `Non-HTTPS: ${hasNonHttps ? 'present' : 'none'}; Broken: ${hasBroken ? 'present' : 'none'}`,
            score: (hasNonHttps || hasBroken) ? 'medneg' : 'pos',
            label: (hasNonHttps || hasBroken) ? '⚠️ Medium Negative' : '👍 Positive'
          });
          const blocklistAny = !!(metrics.blocklist && metrics.blocklist.any_listed);
          rows.push({
            cat: 'Blocklist',
            signal: blocklistAny ? 'Blocklist listings detected' : 'No blocklist hits detected',
            score: blocklistAny ? 'strongneg' : 'pos',
            label: blocklistAny ? '🚨 Strong Negative' : '👍 Positive'
          });

          const headerIssue = (issues || []).some(i => (i || '').toLowerCase().includes('header'));
          rows.push({
            cat: 'Header Consistency',
            signal: headerIssue ? 'Header inconsistencies detected' : 'Headers look consistent',
            score: headerIssue ? 'medneg' : 'pos',
            label: headerIssue ? '⚠️ Medium Negative' : '👍 Positive'
          });

          if (report.risk_level) {
            rows.push({
              cat: 'Overall Risk',
              signal: `Deliverability risk: ${report.risk_level}`,
              score: report.risk_level === 'High' ? 'strongneg' : (report.risk_level === 'Medium' ? 'medneg' : 'pos'),
              label: report.risk_level === 'High' ? '🚨 Strong Negative' : (report.risk_level === 'Medium' ? '⚠️ Medium Negative' : '👍 Positive')
            });
          }

          return rows;
        },
        // Filtered Account Info
        emlSignalCounts() {
          const counts = { pos: 0, neutral: 0, neg: 0, strong: 0 };
          (this.emlSignalRowsComputed || []).forEach(r => {
            if (r.score === 'pos') counts.pos += 1;
            else if (r.score === 'neutral') counts.neutral += 1;
            else if (r.score === 'strongneg') counts.strong += 1;
            else counts.neg += 1;
          });
          return counts;
        },
        emlSignalFiltered() {
          const q = (this.emlSignalSearch || '').toLowerCase();
          return (this.emlSignalRowsComputed || []).filter(r => {
            const matchF = this.emlSignalFilter === 'all'
              || (this.emlSignalFilter === 'pos' && r.score === 'pos')
              || (this.emlSignalFilter === 'neutral' && r.score === 'neutral')
              || (this.emlSignalFilter === 'neg' && ['medneg','slightneg'].includes(r.score))
              || (this.emlSignalFilter === 'strong' && r.score === 'strongneg');
            const matchQ = !q || r.cat.toLowerCase().includes(q) || r.signal.toLowerCase().includes(q) || r.label.toLowerCase().includes(q);
            return matchF && matchQ;
          });
        },
        emlSignalSorted() {
          let data = [...(this.emlSignalFiltered || [])];
          if (this.emlSignalSortCol) {
            const scoreOrder = { pos: 0, neutral: 1, slightneg: 2, medneg: 3, strongneg: 4 };
            data.sort((a, b) => {
              const va = this.emlSignalSortCol === 'score' ? scoreOrder[a.score] : a[this.emlSignalSortCol].toLowerCase();
              const vb = this.emlSignalSortCol === 'score' ? scoreOrder[b.score] : b[this.emlSignalSortCol].toLowerCase();
              if (va < vb) return -this.emlSignalSortDir;
              if (va > vb) return this.emlSignalSortDir;
              return 0;
            });
          }
          return data;
        },
        filteredAccountInfo() {
          if (!this.accountInfo || !this.accountInfo.data) return [];

          return this.accountInfo.data.filter(item => {
            // Apply all filters
            if (this.accountInfoFilters.esp && !item.esp.toLowerCase().includes(this.accountInfoFilters.esp.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.region && !item.region.toLowerCase().includes(this.accountInfoFilters.region.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.domain && !item.domain.toLowerCase().includes(this.accountInfoFilters.domain.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.account_name && !item.account_name.toLowerCase().includes(this.accountInfoFilters.account_name.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.ip_addresses && !item.ip_addresses.toLowerCase().includes(this.accountInfoFilters.ip_addresses.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.subaccount && !item.subaccount.toLowerCase().includes(this.accountInfoFilters.subaccount.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.ip_pool && !item.ip_pool.toLowerCase().includes(this.accountInfoFilters.ip_pool.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.status && !item.status.toLowerCase().includes(this.accountInfoFilters.status.toLowerCase())) {
              return false;
            }
            if (this.accountInfoFilters.verified) {
              const verifiedFilter = this.accountInfoFilters.verified.toLowerCase();
              const itemVerified = item.verified ? 'yes' : 'no';
              if (!itemVerified.includes(verifiedFilter)) {
                return false;
              }
            }
            if (this.accountInfoFilters.created_at && !item.created_at.toLowerCase().includes(this.accountInfoFilters.created_at.toLowerCase())) {
              return false;
            }
            return true;
          });
        },

        // GPT Computed Property
        sortedGPTTable() {
          if (!this.gptOverviewTable) return [];

          const sorted = [...this.gptOverviewTable].sort((a, b) => {
            let aVal = a[this.gptSortColumn];
            let bVal = b[this.gptSortColumn];

            // Handle special cases
            if (this.gptSortColumn === 'ip_reputation') {
              // Sort by first reputation key alphabetically
              aVal = Object.keys(a.ip_reputation || {})[0] || '';
              bVal = Object.keys(b.ip_reputation || {})[0] || '';
            }

            // Convert to lowercase for string comparison
            if (typeof aVal === 'string') aVal = aVal.toLowerCase();
            if (typeof bVal === 'string') bVal = bVal.toLowerCase();

            if (aVal < bVal) return this.gptSortOrder === 'asc' ? -1 : 1;
            if (aVal > bVal) return this.gptSortOrder === 'asc' ? 1 : -1;
            return 0;
          });

          return sorted;
        },

        // GPT Stats Computed Property
        gptStats() {
          if (!this.gptOverviewTable || this.gptOverviewTable.length === 0) {
            return {
              totalDomains: 0,
              domainRep: { HIGH: 0, MEDIUM: 0, LOW: 0, BAD: 0 },
              ipRep: { HIGH: 0, MEDIUM: 0, LOW: 0, BAD: 0 }
            };
          }

          const stats = {
            totalDomains: this.gptOverviewTable.length,
            domainRep: { HIGH: 0, MEDIUM: 0, LOW: 0, BAD: 0 },
            ipRep: { HIGH: 0, MEDIUM: 0, LOW: 0, BAD: 0 }
          };

          this.gptOverviewTable.forEach(item => {
            // Count domain reputation
            if (item.domain_reputation && stats.domainRep[item.domain_reputation] !== undefined) {
              stats.domainRep[item.domain_reputation]++;
            }

            // Count IP reputation
            if (item.ip_reputation && typeof item.ip_reputation === 'object') {
              Object.keys(item.ip_reputation).forEach(rep => {
                if (stats.ipRep[rep] !== undefined) {
                  stats.ipRep[rep] += item.ip_reputation[rep];
                }
              });
            }
          });

          return stats;
        }
      },

