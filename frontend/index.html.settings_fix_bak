        async dnsDeleteSelector(esp, selector) {
          try {
            const res = await fetch(`${this.API_BASE}/api/dns/settings/esp-selectors?esp=${encodeURIComponent(esp)}&selector=${encodeURIComponent(selector)}`, {
              method: 'DELETE'
            });
            const data = await res.json();
            this.dnsEspSelectors = data.selectors || {};
          } catch (e) {
            this.dnsSettingsError = 'Failed to delete selector.';
          }
        },

        async dnsToggleRecipient(recipient, event) {
          const enabled = event.target.checked;
          recipient.enabled = enabled ? 1 : 0;
          try {
            await fetch(`${this.API_BASE}/api/dns/settings/alert-recipients/toggle`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: recipient.email, enabled })
            });
          } catch (e) {
            // Revert on failure
            recipient.enabled = enabled ? 0 : 1;
          }
        }
      },
      watch: {
        daActiveSubTab(newVal) {
          if (newVal === 'dns-looker') {
            if (this.dnsMonitorDomains.length === 0) this.dnsLoadMonitor();
            this.dnsLoadUnreadCount();
          }
        }
      },
      mounted() {
        // Auto-load pulsation data
        this.fetchPulsationData();
        // Set default dates for MBR
        this.setDefaultDates();
        // Load saved reports and email recipients
        this.fetchSavedReports();
        this.fetchRecipients();
        this.fetchMBRMonthlySent();
        // Load account mappings
        this.loadAccountMappings();
        // Check GPT authorization status
        this.checkGPTAuthStatus();
        // Load industry updates
        this.loadIndustryUpdates();
      },
      watch: {
        gptTimePeriod() {
          if (this.gptAuthorized) {
            this.loadGPTData();
          }
        },

        // Auto-load data when navigating to specific pages
        activePage(newPage, oldPage) {
          // Auto-load SNDS data
          if (newPage === 'snds') {
            this.loadSNDSData();
          }

          // Auto-load GPT data (if authorized)
          if (newPage === 'gpt' && this.gptAuthorized) {
            this.loadGPTData();
          }

          // Auto-load Account Info data
          if (newPage === 'info') {
            this.fetchAccountInfo();
          }

          if (newPage === 'mappings_rails') {
            this.loadAccountMappingsRails();
          }

        }
      }
    });

    // Mount app and expose globally for debugging
    window.app = vueApp.mount('#app');
    console.log('✅ Vue app mounted. Access via window.app or just app in console');
  </script>
</body>
</html>
