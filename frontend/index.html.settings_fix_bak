            rows
              .filter(row => (row.From_domain || '').toLowerCase() === (this.selectedDomain || '').toLowerCase())
              .map(row => (row.ESP || '').trim())
              .filter(Boolean)
          )];

          if (esps.length === 1) {
            return { esp: esps[0], error: null };
